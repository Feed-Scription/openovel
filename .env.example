# You can keep using environment variables, but the preferred durable setup is
# .openovel/settings.jsonc. See docs/configuration.md.

# Default: Kimi Code Coding Plan
AI_PROVIDER=kimi-code
KIMI_API_KEY=
KIMI_MODEL_NAME=kimi-for-coding

# Optional: use a separate provider/model for the fast foreground narrator.
# AI_FOREGROUND_PROVIDER=kimi-code
# AI_FOREGROUND_MODEL=kimi-for-coding

# Optional: use a separate provider/model for background Storykeeper work.
# AI_BACKGROUND_PROVIDER=kimi-code
# AI_BACKGROUND_MODEL=kimi-for-coding

# Both default to AI_PROVIDER / AI_MODEL when unset. Set both to run a cheap
# fast model in the foreground and a smarter reasoning model in the background
# without sharing the same vendor.

# Optional: opencode-style model profiles. Keep fast helpers cheap; use the
# background/reasoning model only where it buys quality.
# AI_SMALL_MODEL=kimi-for-coding
# AI_SIGNAL_MODEL=kimi-for-coding
# AI_MEMORY_MODEL=kimi-for-coding
# AI_SUMMARY_MODEL=kimi-for-coding
# AI_COMPACTION_MODEL=kimi-for-coding
# OPENOVEL_STORYKEEPER_MODEL=kimi-for-coding
# AI_SUBAGENT_MODEL=kimi-for-coding
# AI_CONTINUITY_MODEL=kimi-for-coding
# AI_RESEARCH_MODEL=kimi-for-coding
# AI_PLANNER_MODEL=kimi-for-coding

# Optional: subscription/token-plan route order. Pay-as-you-go providers are
# skipped as fallback unless AI_ALLOW_PAID_FALLBACK=true.
AI_PROVIDER_ORDER=kimi-code,mimo-token-plan-sgp,mimo-token-plan-cn,mimo-token-plan-ams
AI_ALLOW_PAID_FALLBACK=false

# Optional: concurrent request cap per provider. A single foreground turn can
# fire 5-6 model calls (narrator + options + signal + insert-manifest + the
# slow-loop storykeeper + memory-review). Defaults are 3-4; bump if you see
# turns queueing on the provider semaphore, lower if you see 429s.
# DEEPSEEK_CONCURRENCY=8
# KIMI_CONCURRENCY=6
# MIMO_CONCURRENCY=4
# OPENOVEL_PROVIDER_CONCURRENCY=6     # global fallback for any provider

# Workspace layout. Defaults keep the current story in ./story and global
# user/shared material in ~/.openovel, similar to other local-first agent tools.
# OPENOVEL_HOME=~/.openovel
# OPENOVEL_STORY_ID=suyu-campaign
# OPENOVEL_STORY_ROOT=./story
# OPENOVEL_ONBOARDING_LOCALE=en
# OPENOVEL_SKIP_ONBOARDING=0

# Xiaomi MiMo Token Plan examples. Use the provider matching the Base URL shown
# on your Subscription page; Token Plan keys start with tp- and are region-bound.
# AI_PROVIDER=mimo-token-plan-cn
# AI_PROVIDER=mimo-token-plan-sgp
# AI_PROVIDER=mimo-token-plan-ams
# MIMO_API_KEY=your-token-plan-key
# MIMO_MODEL=mimo-v2.5-pro

# Xiaomi MiMo pay-as-you-go, explicit only.
# AI_PROVIDER=mimo-api
# MIMO_API_KEY=your-mimo-api-key
# MIMO_MODEL=mimo-v2.5-pro

# DeepSeek pay-as-you-go fallback, explicit only.
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=your-deepseek-key
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BACKGROUND_MODEL=deepseek-v4-flash
# AI_SIGNAL_MODEL=deepseek-v4-flash
# AI_MEMORY_MODEL=deepseek-v4-flash
# AI_RESEARCH_MODEL=deepseek-v4-pro

# Generic custom OpenAI-compatible endpoint for future providers.
# AI_PROVIDER=custom-openai
# AI_BASE_URL=https://your-provider.example.com/v1
# AI_API_KEY=your-api-key
# AI_MODEL=your-model
# Capability overrides are generic provider/model metadata. Use these when a
# future OpenAI-compatible endpoint has different tool, stream, JSON, reasoning,
# temperature, or token-limit behavior.
# OPENOVEL_PROVIDER_CAPABILITIES={"custom-openai":{"request":{"tools":true,"jsonMode":true,"maxTokensField":"max_tokens"},"limits":{"contextTokens":128000,"outputTokens":8192}}}
# OPENOVEL_MODEL_CAPABILITIES={"custom-openai/your-model":{"reasoning":{"supported":true,"effort":true},"request":{"temperature":false}}}

PORT=4317

# TUI display pacing is decoupled from provider streaming latency. The default
# is tuned for Chinese modern prose: 720 chars/min, slightly above 600 chars/min.
# OPENOVEL_DISPLAY_CPM=720
# OPENOVEL_DISPLAY_PACING=1
# OPENOVEL_DISPLAY_PUNCTUATION_PAUSES=1

# Suggested choices are optional. Disable them for pure free-form input and to
# skip the post-narration options model call.
# OPENOVEL_OPTIONS_ENABLED=1

# Tool permission policy. Rules are provider/story agnostic: permission +
# pattern + action, using an allow/ask/deny shape.
# Built-in story-scoped tools are allowed; bash stays disabled unless explicit.
# OPENOVEL_ENABLE_BASH_TOOL=0
# OPENOVEL_PERMISSION_ASK_FALLBACK=deny
# OPENOVEL_TOOL_PERMISSION_RULES=[{"permission":"webfetch","pattern":"https://example.com/*","action":"deny","reason":"example blocked"}]

# Foreground context budgets. Long-run evals report raw growth vs inserted
# context, and Storykeeper sees pressure reports when these budgets clip.
# OPENOVEL_CONTEXT_GUIDANCE_CHARS=6000
# OPENOVEL_CONTEXT_INSERT_CHARS=3000
# OPENOVEL_CONTEXT_MEMORY_CHARS=1600
# OPENOVEL_CONTEXT_RECENT_CANON_CHARS=3500

# Model-player evaluation runner. This is a separate DeepSeek-compatible model
# that plays the human reader during evals.
# OPENOVEL_EVAL_DEEPSEEK_API_KEY=your-eval-deepseek-key
# OPENOVEL_EVAL_DEEPSEEK_MODEL=deepseek-v4-pro
# OPENOVEL_EVAL_REASONING_EFFORT=medium
# OPENOVEL_EVAL_DEEPSEEK_BASE_URL=https://api.deepseek.com
# OPENOVEL_EVAL_JUDGE_MODEL=deepseek-v4-pro
# OPENOVEL_EVAL_JUDGE_MAX_TOKENS=384000

# Ablation-only switches used by npm run eval:ablation. Leave unset in normal
# use; the suite sets them per isolated child run.
# OPENOVEL_ABLATION_DISABLE_BACKGROUND=0
# OPENOVEL_ABLATION_DISABLE_STORYKEEPER=0
# OPENOVEL_ABLATION_DISABLE_MEMORY_REVIEW=0
# OPENOVEL_ABLATION_DISABLE_CONTEXT_INSERTS=0

# Web search is provider-routed discovery. The default is a free no-key
# DuckDuckGo HTML provider. websearch writes candidate URLs to
# story/research/search-log.md; webfetch retrieves selected pages separately.
# OPENOVEL_WEBSEARCH_PROVIDER=duckduckgo-html
# OPENOVEL_WEBSEARCH_PROVIDER_ORDER=duckduckgo-html,custom-http-search,kimi-search-service,exa-mcp,parallel-mcp
# OPENOVEL_WEBSEARCH_WRITE_RESULTS=1

# Kimi Code search service. Explicit provider selection; uses KIMI_API_KEY by
# default, override if needed.
# OPENOVEL_WEBSEARCH_PROVIDER=kimi-search-service
# KIMI_SEARCH_API_KEY=your-kimi-code-key
# KIMI_SEARCH_BASE_URL=https://api.kimi.com/coding/v1

# MCP search providers. Configure the hosted/local MCP JSON-RPC endpoint and key.
# OPENOVEL_WEBSEARCH_PROVIDER=exa-mcp
# EXA_MCP_URL=https://your-exa-mcp.example/mcp
# EXA_API_KEY=your-exa-key
# EXA_MCP_TOOL=web_search_exa
# OPENOVEL_WEBSEARCH_PROVIDER=parallel-mcp
# PARALLEL_MCP_URL=https://your-parallel-mcp.example/mcp
# PARALLEL_API_KEY=your-parallel-key
# PARALLEL_MCP_TOOL=web_search

# Anthropic server-side web_search_20250305. Explicit only; this is billed by
# Anthropic in addition to model tokens.
# OPENOVEL_WEBSEARCH_PROVIDER=anthropic-server-websearch
# ANTHROPIC_API_KEY=your-anthropic-key
# ANTHROPIC_SEARCH_MODEL=claude-3-5-haiku-latest

# Generic HTTP JSON discovery endpoint. It should return { "results": [...] }.
# OPENOVEL_WEBSEARCH_PROVIDER=custom-http-search
# CUSTOM_HTTP_SEARCH_URL=https://search.example.test?q={query}&limit={limit}
# CUSTOM_HTTP_SEARCH_API_KEY=your-search-key
